body {
    font-family: Arial;
    background: #f4f6f8;
    padding: 20px;
}

h1 {
    color: #003366;
}

.box {
    background: white;
    padding: 20px;
    margin-bottom: 20px;
    border-radius: 10px;
    width: 400px;
}

input, textarea, select {
    width: 100%;
    margin: 10px 0;
    padding: 10px;
}

button {
    background: #003366;
    color: white;
    padding: 10px;
    border: none;
    cursor: pointer;
}
